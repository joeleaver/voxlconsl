/target
# Per-cart target dirs created by `voxlconsl bundle <project>` when no
# --output is given (default: <project>/target/<cart>.voxl).
/examples/*/target/
**/*.rs.bk
Cargo.lock.bak
.DS_Store
*.voxl
*.vxv.tmp

# wasm-bindgen output, regenerated by scripts/build-web.sh
/web/pkg/

# Cart .voxl copied in by scripts/build-web.sh for include_bytes!
# (older sessions wrote a raw .wasm to the same prefix — keep both
# globbed so the rename doesn't ressurrect stale files in working
# trees that pre-date the cart-format landing.)
/crates/host-browser/embedded-cart.*

# Diagnostic screenshots from playwright runs
/*.png
/.playwright-mcp/

# mdBook output (regenerated by `mdbook build docs` and CI)
/docs/book/

# Pages deploy staging dir (assembled by CI)
/site/

# editor / OS
*.swp
.idea/
.vscode/

# Python (scripts/flf_to_vfnt.py and friends)
__pycache__/
*.pyc

